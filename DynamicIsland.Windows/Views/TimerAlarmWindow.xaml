<Window x:Class="DynamicIsland.Windows.Views.TimerAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer and Alarm" Width="430" Height="720" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True">
    <Border Margin="10" CornerRadius="22" Background="#F3161B24" BorderBrush="#42FFFFFF" BorderThickness="1" Padding="22">
        <Border.Effect><DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.55" /></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="Timer and Alarm" FontFamily="Segoe UI Variable Display" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                <Button Content="&#xE711;" HorizontalAlignment="Right" Click="Close_Click" Style="{StaticResource IslandIconButton}" />
            </Grid>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,12">
                <StackPanel>
                    <Border Background="#16FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1" CornerRadius="14" Padding="16">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Timer" FontSize="15" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="{Binding TimerStateText}" HorizontalAlignment="Right" Foreground="#7EB8FF" />
                            </Grid>
                            <TextBlock Text="{Binding TimerRemaining}" FontFamily="Segoe UI Variable Display" FontSize="36" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,10" />
                            <ProgressBar Value="{Binding TimerProgress, Mode=OneWay}" Height="5" Foreground="#5AA7FF" Background="#24FFFFFF" BorderThickness="0" />
                            <WrapPanel HorizontalAlignment="Center" Margin="0,14,0,8">
                                <Button Content="5m" Command="{Binding StartPresetCommand}" CommandParameter="5" Style="{StaticResource SettingsButton}" Margin="3" Padding="12,7" />
                                <Button Content="10m" Command="{Binding StartPresetCommand}" CommandParameter="10" Style="{StaticResource SettingsButton}" Margin="3" Padding="12,7" />
                                <Button Content="15m" Command="{Binding StartPresetCommand}" CommandParameter="15" Style="{StaticResource SettingsButton}" Margin="3" Padding="12,7" />
                                <Button Content="25m" Command="{Binding StartPresetCommand}" CommandParameter="25" Style="{StaticResource SettingsButton}" Margin="3" Padding="12,7" />
                                <Button Content="30m" Command="{Binding StartPresetCommand}" CommandParameter="30" Style="{StaticResource SettingsButton}" Margin="3" Padding="12,7" />
                            </WrapPanel>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBox Text="{Binding CustomMinutes}" Padding="8,7" ToolTip="Minutes" />
                                <TextBox Grid.Column="1" Text="{Binding TimerLabel}" Padding="8,7" Margin="8,0" ToolTip="Optional label" />
                                <Button Grid.Column="2" Content="Start" Command="{Binding StartCustomCommand}" Style="{StaticResource SettingsButton}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Content="{Binding TimerPrimaryText}" Command="{Binding TimerPrimaryCommand}" Style="{StaticResource SettingsButton}" Margin="4" />
                                <Button Content="Reset" Command="{Binding ResetTimerCommand}" Style="{StaticResource SettingsButton}" Background="#394252" Margin="4" />
                                <Button Content="Cancel" Command="{Binding CancelTimerCommand}" Style="{StaticResource SettingsButton}" Background="#394252" Margin="4" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#16FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,14,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Alarm" FontSize="15" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="{Binding AlarmStateText}" HorizontalAlignment="Right" Foreground="#7EB8FF" />
                            </Grid>
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="60" /><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBox Text="{Binding AlarmHour}" Padding="8,7" Margin="0,0,6,0" />
                                <TextBox Grid.Column="1" Text="{Binding AlarmMinute}" Padding="8,7" Margin="0,0,6,0" />
                                <ComboBox Grid.Column="2" SelectedValue="{Binding AmPm}" SelectedValuePath="Content" Padding="8,5" Margin="0,0,6,0">
                                    <ComboBoxItem Content="AM" /><ComboBoxItem Content="PM" />
                                </ComboBox>
                                <TextBox Grid.Column="3" Text="{Binding AlarmLabel}" Padding="8,7" ToolTip="Optional label" />
                            </Grid>
                            <CheckBox Content="24-hour time" IsChecked="{Binding Use24Hour}" Foreground="#C8D0DC" Margin="0,10,0,0" />
                            <WrapPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Content="Set Alarm" Command="{Binding SetAlarmCommand}" Style="{StaticResource SettingsButton}" Margin="4" />
                                <Button Content="Delete" Command="{Binding DeleteAlarmCommand}" Style="{StaticResource SettingsButton}" Background="#394252" Margin="4" />
                                <Button Content="Dismiss" Command="{Binding DismissAlarmCommand}" Style="{StaticResource SettingsButton}" Background="#C74343" Margin="4" />
                                <Button Content="Snooze 5m" Command="{Binding Snooze5Command}" Style="{StaticResource SettingsButton}" Background="#946C2B" Margin="4" />
                                <Button Content="Snooze 10m" Command="{Binding Snooze10Command}" Style="{StaticResource SettingsButton}" Background="#946C2B" Margin="4" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#16FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Stopwatch" FontSize="15" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="{Binding StopwatchText}" FontFamily="Segoe UI Variable Display" FontSize="34" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,14,0,10" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="{Binding StopwatchPrimaryText}" Command="{Binding StopwatchPrimaryCommand}" Style="{StaticResource SettingsButton}" Margin="4" />
                                <Button Content="Lap" Command="{Binding StopwatchLapCommand}" Style="{StaticResource SettingsButton}" Background="#394252" Margin="4" />
                                <Button Content="Reset" Command="{Binding StopwatchResetCommand}" Style="{StaticResource SettingsButton}" Background="#394252" Margin="4" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Laps}" Margin="0,12,0,0" MaxHeight="140">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter /></ScrollViewer></ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding}" Foreground="#C8D0DC" FontSize="12.5" Margin="2,2" HorizontalAlignment="Center" /></DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <TextBlock Grid.Row="2" Text="Timer and alarm state is saved automatically." HorizontalAlignment="Center"
                       Foreground="#7E8B9E" FontSize="10" />
        </Grid>
    </Border>
</Window>
