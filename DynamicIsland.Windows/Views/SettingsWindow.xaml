<Window x:Class="DynamicIsland.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dynamic Island Settings" Width="940" Height="700" MinWidth="840" MinHeight="560"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource SettingsBackgroundBrush}"
        Foreground="{DynamicResource SettingsTextBrush}" FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,14" />
        </Style>
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsMutedBrush}" />
            <Setter Property="Margin" Value="6,16,0,8" />
        </Style>
        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="RowDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsMutedBrush}" />
            <Setter Property="Margin" Value="0,2,12,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="44" Height="26" CornerRadius="13" Background="#3C4654" BorderBrush="#54606E" BorderThickness="1">
                            <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9" Background="#CBD4DF" HorizontalAlignment="Left" Margin="4,0,0,0">
                                <Border.RenderTransform><TranslateTransform x:Name="ThumbT" X="0" /></Border.RenderTransform>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2587FF" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#2587FF" />
                                <Setter TargetName="Thumb" Property="Background" Value="#FFFFFF" />
                                <Trigger.EnterActions><BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ThumbT" Storyboard.TargetProperty="X" To="18" Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6" /></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation></Storyboard></BeginStoryboard></Trigger.EnterActions>
                                <Trigger.ExitActions><BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ThumbT" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation></Storyboard></BeginStoryboard></Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource SettingsTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6" Margin="4,2" Padding="11,8"><ContentPresenter /></Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="b" Property="Background" Value="#2587FF" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="b" Property="Background" Value="#33558BFF" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Width" Value="220" /><Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" /><Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template><ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd" Background="{DynamicResource SettingsInputBrush}" BorderBrush="{DynamicResource SettingsCardBorderBrush}" BorderThickness="1" CornerRadius="9" />
                                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="BorderBrush" Value="#4D8AD8FF" /></Trigger></ControlTemplate.Triggers>
                                </ControlTemplate></ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="13,0,32,0" VerticalAlignment="Center" IsHitTestVisible="False" TextElement.Foreground="{DynamicResource SettingsTextBrush}" />
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10" HorizontalAlignment="Right" Margin="0,0,13,0" VerticalAlignment="Center" Foreground="{DynamicResource SettingsMutedBrush}" IsHitTestVisible="False" />
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource SettingsCardBrush}" BorderBrush="{DynamicResource SettingsCardBorderBrush}" BorderThickness="1" CornerRadius="9" Margin="0,5,0,0" Padding="2" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.45" Color="#000000" /></Border.Effect>
                                    <ScrollViewer MaxHeight="280"><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSlider" TargetType="Slider">
            <Setter Property="Width" Value="178" /><Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" /><Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="22">
                            <Border Height="5" CornerRadius="3" Background="#3C4654" VerticalAlignment="Center" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton><RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="5" CornerRadius="3" Background="#2587FF" VerticalAlignment="Center" /></ControlTemplate></RepeatButton.Template>
                                </RepeatButton></Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton><RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" /></ControlTemplate></RepeatButton.Template>
                                </RepeatButton></Track.IncreaseRepeatButton>
                                <Track.Thumb><Thumb Width="18" Height="18">
                                    <Thumb.Template><ControlTemplate TargetType="Thumb">
                                        <Ellipse Width="18" Height="18" Fill="#FFFFFF"><Ellipse.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.4" /></Ellipse.Effect></Ellipse>
                                    </ControlTemplate></Thumb.Template>
                                </Thumb></Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text input -->
        <Style x:Key="TextInput" TargetType="TextBox">
            <Setter Property="Height" Value="34" /><Setter Property="Width" Value="160" />
            <Setter Property="VerticalContentAlignment" Value="Center" /><Setter Property="Padding" Value="11,0" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource SettingsTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{DynamicResource SettingsInputBrush}" BorderBrush="{DynamicResource SettingsCardBorderBrush}" BorderThickness="1" CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsFocused" Value="True"><Setter TargetName="bd" Property="BorderBrush" Value="#2587FF" /></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar item -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" CornerRadius="9" Margin="8,2" Padding="11,9" Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="15" VerticalAlignment="Center" Width="24" Foreground="{DynamicResource SettingsMutedBrush}" />
                                <TextBlock Text="{Binding Name}" FontSize="13.5" VerticalAlignment="Center" Foreground="{DynamicResource SettingsTextBrush}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#14FFFFFF" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="bd" Property="Background" Value="#2587FF" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SettingsHeaderBrush}" BorderBrush="#16FFFFFF" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="18,20,18,12">
                    <Border Width="38" Height="38" CornerRadius="11" Background="#2587FF" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7C4;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Dynamic Island" FontFamily="Segoe UI Variable Display" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Settings" FontSize="11.5" Foreground="{DynamicResource SettingsMutedBrush}" />
                    </StackPanel>
                </StackPanel>
                <Border Grid.Row="1" Margin="14,2,14,8" Height="34" CornerRadius="9" Background="{DynamicResource SettingsInputBrush}" BorderBrush="{DynamicResource SettingsCardBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="11,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource SettingsMutedBrush}" />
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Margin="8,0,8,0"
                                 Foreground="{DynamicResource SettingsTextBrush}" CaretBrush="{DynamicResource SettingsTextBrush}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
                <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0" ItemsSource="{Binding Sections}"
                         SelectedValuePath="Key" SelectedValue="{Binding SelectedSectionKey}"
                         ItemContainerStyle="{StaticResource NavItem}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                <Button Grid.Row="3" Content="Done" Command="{Binding CloseCommand}" Margin="14" Style="{StaticResource SettingsButton}" />
            </Grid>
        </Border>

        <!-- ===== Content ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="34,26,34,26">
            <Grid>
                <!-- GENERAL -->
                <StackPanel Visibility="{Binding SelectedSectionKey, Converter={StaticResource SectionVisibility}, ConverterParameter=general}">
                    <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Launch on startup" Style="{StaticResource RowTitle}" /><TextBlock Text="Open the island automatically when you sign in." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LaunchOnStartup}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Always on top" Style="{StaticResource RowTitle}" /><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AlwaysOnTop}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Always expanded" Style="{StaticResource RowTitle}" /><TextBlock Text="Keep the island open instead of collapsing." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AlwaysExpanded}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Expand on hover" Style="{StaticResource RowTitle}" /><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ExpandOnHover}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Lock position" Style="{StaticResource RowTitle}" /><TextBlock Text="Prevent dragging the island out of place." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LockPosition}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Click-through when compact" Style="{StaticResource RowTitle}" /><TextBlock Text="Pass clicks to apps behind it." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ClickThroughWhenCompact}" /></Grid>
                    </StackPanel></Border>
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Auto-hide in fullscreen" Style="{StaticResource RowTitle}" /><TextBlock Text="Hide while a fullscreen app or game is focused." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AutoHideFullscreen}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Idle dimming" Style="{StaticResource RowTitle}" /><TextBlock Text="Fade the island when left alone; restore on hover." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IdleDimming}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Idle opacity" Style="{StaticResource RowTitle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="20" Maximum="100" Value="{Binding IdleOpacityPercent}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding IdleOpacityPercent, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                    </StackPanel></Border>
                </StackPanel>

                <!-- APPEARANCE -->
                <StackPanel Visibility="{Binding SelectedSectionKey, Converter={StaticResource SectionVisibility}, ConverterParameter=appearance}">
                    <TextBlock Text="Appearance" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Theme" Style="{StaticResource RowTitle}" /><ComboBox Grid.Column="1" Style="{StaticResource SettingsCombo}" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Font" Style="{StaticResource RowTitle}" /><ComboBox Grid.Column="1" Style="{StaticResource SettingsCombo}" ItemsSource="{Binding FontOptions}" SelectedItem="{Binding FontFamilyName}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Liquid glass" Style="{StaticResource RowTitle}" /><TextBlock Text="Translucent frosted glass material." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LiquidGlass}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Glass transparency" Style="{StaticResource RowTitle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="0" Maximum="80" Value="{Binding GlassTransparency}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding GlassTransparency, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                    </StackPanel></Border>
                    <TextBlock Text="COLOURS" Style="{StaticResource GroupHeader}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Custom colours" Style="{StaticResource RowTitle}" /><TextBlock Text="Override accent, text and glass colours." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding UseCustomColors}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Adaptive accent" Style="{StaticResource RowTitle}" /><TextBlock Text="Pull the accent colour from the album art." Style="{StaticResource RowDesc}" /></StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AdaptiveAccent}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Accent colour" Style="{StaticResource RowTitle}" Margin="0,2,0,8" />
                        <ItemsControl ItemsSource="{Binding AccentSwatches}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Width="30" Height="30" Margin="0,0,8,8" Cursor="Hand"
                                        Command="{Binding DataContext.PickAccentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border CornerRadius="15" Background="{Binding}" BorderBrush="#55FFFFFF" BorderThickness="2" />
                                    </ControlTemplate></Button.Template>
                                </Button>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Accent hex" Style="{StaticResource RowTitle}" /><TextBox Grid.Column="1" Style="{StaticResource TextInput}" Text="{Binding AccentColorHex, UpdateSourceTrigger=LostFocus}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Text colour hex" Style="{StaticResource RowTitle}" /><TextBlock Text="Leave blank to follow the theme." Style="{StaticResource RowDesc}" /></StackPanel>
                            <TextBox Grid.Column="1" Style="{StaticResource TextInput}" Text="{Binding TextColorHex, UpdateSourceTrigger=LostFocus}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Glass colour hex" Style="{StaticResource RowTitle}" /><TextBlock Text="Leave blank for the default tint." Style="{StaticResource RowDesc}" /></StackPanel>
                            <TextBox Grid.Column="1" Style="{StaticResource TextInput}" Text="{Binding GlassColorHex, UpdateSourceTrigger=LostFocus}" /></Grid>
                    </StackPanel></Border>
                    <TextBlock Text="SKINS" Style="{StaticResource GroupHeader}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <TextBlock Text="One-tap looks — sets colours, glass and font together." Style="{StaticResource RowDesc}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding ThemeSkins}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Content="{Binding}" Command="{Binding DataContext.ApplySkinCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                        Style="{StaticResource SettingsButton}" Background="{DynamicResource SettingsSubtleButtonBrush}" Foreground="{DynamicResource SettingsTextBrush}" Margin="0,0,8,8" />
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel></Border>
                </StackPanel>

                <!-- SIZES -->
                <StackPanel Visibility="{Binding SelectedSectionKey, Converter={StaticResource SectionVisibility}, ConverterParameter=sizes}">
                    <TextBlock Text="Text &amp; Sizes" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Interface scale" Style="{StaticResource RowTitle}" /><TextBlock Text="Master multiplier for every element." Style="{StaticResource RowDesc}" /></StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="70" Maximum="150" Value="{Binding InterfaceScale}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding InterfaceScale, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Clock" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding ClockSize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding ClockSize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Date" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding DateSize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding DateSize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Battery &amp; charging" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding BatterySize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding BatterySize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Media title" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding MediaTitleSize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding MediaTitleSize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Media artist" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding MediaArtistSize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding MediaArtistSize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Volume" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Slider Style="{StaticResource SettingsSlider}" Minimum="60" Maximum="160" Value="{Binding VolumeSize}" TickFrequency="5" IsSnapToTickEnabled="True" /><TextBlock Text="{Binding VolumeSize, StringFormat={}{0}%}" Width="44" TextAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SettingsMutedBrush}" /></StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
