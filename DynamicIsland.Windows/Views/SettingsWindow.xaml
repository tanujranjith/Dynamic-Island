                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Pause media when away" Style="{StaticResource RowTitle}" /><TextBlock Text="Pause playback when you leave, resume when you return." Style="{StaticResource RowDesc}" /></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding PresenceAwareMedia}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Privacy blur" Style="{StaticResource RowTitle}" /><TextBlock Text="Frost the screen when an unknown person appears." Style="{StaticResource RowDesc}" /></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding PrivacyAutoBlur}" /></Grid>
                    </StackPanel></Border>
                </StackPanel>

                <!-- ADVANCED -->
                <StackPanel Visibility="{Binding SelectedSectionKey, Converter={StaticResource SectionVisibility}, ConverterParameter=advanced}">
                    <TextBlock Text="Advanced" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="PROFILES" Style="{StaticResource GroupHeader}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <ComboBox Style="{StaticResource SettingsCombo}" Width="220" HorizontalAlignment="Left" ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Apply" Command="{Binding ApplyPresetCommand}" Style="{StaticResource SettingsButton}" Background="{DynamicResource SettingsSubtleButtonBrush}" Foreground="{DynamicResource SettingsTextBrush}" Margin="0,0,8,0" />
                                <Button Content="Delete" Command="{Binding DeletePresetCommand}" Style="{StaticResource SettingsButton}" Background="#3A2630" Foreground="#FFB4B4" />
                            </StackPanel></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource TextInput}" Width="220" HorizontalAlignment="Left" Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Save current as preset" Command="{Binding SavePresetCommand}" Style="{StaticResource SettingsButton}" /></Grid>
                    </StackPanel></Border>
                    <TextBlock Text="BACKUP" Style="{StaticResource GroupHeader}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Import / export settings" Style="{StaticResource RowTitle}" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Import" Command="{Binding ImportCommand}" Style="{StaticResource SettingsButton}" Background="{DynamicResource SettingsSubtleButtonBrush}" Foreground="{DynamicResource SettingsTextBrush}" Margin="0,0,8,0" /><Button Content="Export" Command="{Binding ExportCommand}" Style="{StaticResource SettingsButton}" Background="{DynamicResource SettingsSubtleButtonBrush}" Foreground="{DynamicResource SettingsTextBrush}" /></StackPanel></Grid>
                    </StackPanel></Border>
                    <TextBlock Text="DEVELOPER" Style="{StaticResource GroupHeader}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Debug overlay" Style="{StaticResource RowTitle}" /><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding DebugOverlay}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Debug logging" Style="{StaticResource RowTitle}" /><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding DebugLogging}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Show in Alt-Tab" Style="{StaticResource RowTitle}" /><CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowInAltTab}" /></Grid>
                    </StackPanel></Border>
                </StackPanel>

                <!-- ABOUT -->
                <StackPanel Visibility="{Binding SelectedSectionKey, Converter={StaticResource SectionVisibility}, ConverterParameter=about}">
                    <TextBlock Text="About" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource SettingsCard}"><StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <Border Width="52" Height="52" CornerRadius="15" Background="#2587FF" VerticalAlignment="Center"><TextBlock Text="&#xE7C4;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Dynamic Island for Windows" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="A native overlay with media, camera, weather and more." FontSize="12" Foreground="{DynamicResource SettingsMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <Border Style="{StaticResource Divider}" />
                        <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Recenter island" Style="{StaticResource RowTitle}" /><TextBlock Text="Move the island back to the top centre." Style="{StaticResource RowDesc}" /></StackPanel>
                            <Button Grid.Column="1" Content="Recenter" Command="{Binding RecenterCommand}" Style="{StaticResource SettingsButton}" Background="{DynamicResource SettingsSubtleButtonBrush}" Foreground="{DynamicResource SettingsTextBrush}" /></Grid>
                        <Border Style="{StaticResource Divider}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Reset everything" Style="{StaticResource RowTitle}" /><TextBlock Text="Restore all settings to their defaults." Style="{StaticResource RowDesc}" /></StackPanel>
                            <Button Grid.Column="1" Content="Reset to defaults" Command="{Binding ResetCommand}" Style="{StaticResource SettingsButton}" Background="#3A2630" Foreground="#FFB4B4" /></Grid>
                    </StackPanel></Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
