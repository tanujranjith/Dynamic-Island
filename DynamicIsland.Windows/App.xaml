<Application x:Class="DynamicIsland.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inf="clr-namespace:DynamicIsland.Windows.Infrastructure"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <inf:RingProgressConverter x:Key="RingProgress" />
        <inf:DoubleToCornerRadiusConverter x:Key="DoubleToCorner" />
        <inf:StringEqualsToVisibilityConverter x:Key="SectionVisibility" />
        <inf:StringEqualsToBoolConverter x:Key="SectionSelected" />

        <SolidColorBrush x:Key="AccentBrush" Color="#5AA7FF" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#2587FF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F7FAFF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAB5C6" />
        <SolidColorBrush x:Key="CardBrush" Color="#161B24" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2C3544" />
        <SolidColorBrush x:Key="SettingsBackgroundBrush" Color="#11151C" />
        <SolidColorBrush x:Key="SettingsHeaderBrush" Color="#181D26" />
        <SolidColorBrush x:Key="SettingsCardBrush" Color="#1B222D" />
        <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="#354052" />
        <SolidColorBrush x:Key="SettingsTextBrush" Color="#F1F5FB" />
        <SolidColorBrush x:Key="SettingsMutedBrush" Color="#9AA8BB" />
        <SolidColorBrush x:Key="SettingsInputBrush" Color="#242D3A" />
        <SolidColorBrush x:Key="SettingsSubtleButtonBrush" Color="#303A49" />

        <Style x:Key="IslandIconButton" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F6F8FC" />
            <Setter Property="Background" Value="#1CFFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Border x:Name="ButtonChrome" CornerRadius="16"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <Border x:Name="Hover" CornerRadius="16" Background="#3A72B7FF"
                                    BorderBrush="#665AA7FF" BorderThickness="1" Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Hover" Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Hover" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="0.88" Duration="0:0:0.09" />
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="0.88" Duration="0:0:0.09" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.44">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="1.1" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.44">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="1.1" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2587FF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="8" Background="{TemplateBinding Background}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1" /></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Opacity" To="0.88" Duration="0:0:0.14" />
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.09" />
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.09" />
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.85" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.85" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Application.Resources>
</Application>
